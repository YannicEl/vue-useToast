{
	"name": "docs",
	"type": "module",
	"scripts": {
		"dev": "vitepress dev --port 3000",
		"build": "vitepress build",
		"preview": "vitepress preview",
		"deploy:dev": "wrangler pages deploy .vitepress/dist --project-name vuetils-toast-docs --branch dev --commit-dirty",
		"deploy:prod": "wrangler pages deploy .vitepress/dist --project-name vuetils-toast-docs --branch main --commit-dirty"
	},
	"dependencies": {
		"@vuetils/toast": "workspace:*",
		"vue": "3.5.12"
	},
	"devDependencies": {
		"sass": "1.80.2",
		"unocss": "0.63.4",
		"vitepress": "1.4.1",
		"wrangler": "3.81.0"
	}
}
